var POST_CONFIG = {
  user:        'pavelzosim',
  path:        '~/unity',
  command:     'cat unity_shaderlab.log',
  prefix:      'SYSTEM_ATLAS // R&D_LOG',
  project:     'UNITY_SHADERLAB',
  module:      'surface_shaders',
  version:     '1.3.3',
  logId:       '#003',
  status:      'STABLE',
  slug:        'unity-shaderlab-cheatsheet',
  author:      '...',
  created:     '----.--.--',
  modified:    null,
  wordCount:   2400,
  title:       null,
  tags:        [],
  tagBaseUrl:  'https://www.pavelzosim.com/blog/tags/',
  footerLabel: '// END OF LOG — UNITY_SHADERLAB',
  footerAuthor: 'pavelzosim',
  footerYear:   '2025',
  terminalLines: [
	'**[ATLAS_COMPILE]** unity_shaderlab.log',
	'> ShaderLab syntax: ~~OK~~',
	'> Surface shader variants: ~~compiled (14)~~',
