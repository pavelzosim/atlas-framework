<script>
/* ═══════════════════════════════════════════════════════════════
   AUTO-FETCH
═══════════════════════════════════════════════════════════════ */
var BACKEND_URL = 'https://www.pavelzosim.com/_functions/getPostData';

function applyPostData(d) {
  if (d.author)                 POST_CONFIG.author   = d.author;
  if (d.title)                  POST_CONFIG.title    = d.title;
  if (d.created)                POST_CONFIG.created  = d.created;
  if (d.modified !== undefined) POST_CONFIG.modified = d.modified;
  if (Array.isArray(d.tags) && d.tags.length) POST_CONFIG.tags = d.tags;
  if (window._atlasAF) runWithFramework(window._atlasAF);
}

(function () {
  var slug = POST_CONFIG.slug || '';
  if (!slug) return;
  fetch(BACKEND_URL + '?slug=' + encodeURIComponent(slug))
    .then(function (r) { return r.ok ? r.json() : null; })
    .then(function (data) { if (data && !data.error) applyPostData(data); })
    .catch(function () {});
})();

/* ═══════════════════════════════════════════════════════════════
   FRAMEWORK INIT
═══════════════════════════════════════════════════════════════ */
(function () {
  function tryInit() {
    if (window.AtlasFramework) { runWithFramework(window.AtlasFramework); }
    else { runWithFramework(buildFallbackFramework()); }
  }

  function runWithFramework(AF) {
    window._atlasAF = AF;
    var fb = document.getElementById('post-meta-fallback');
    if (fb) fb.style.display = 'none';
    AF.renderEngineeringPassport('#post-passport', {
      user:      POST_CONFIG.user,
      path:      POST_CONFIG.path,
      command:   POST_CONFIG.command,
      prefix:    POST_CONFIG.prefix,
      project:   POST_CONFIG.project,
      module:    POST_CONFIG.module,
      version:   POST_CONFIG.version,
      logId:     POST_CONFIG.logId,
      status:    POST_CONFIG.status,
      author:    POST_CONFIG.author,
      title:     POST_CONFIG.title,
      created:   POST_CONFIG.created,
      modified:  POST_CONFIG.modified,
      wordCount: POST_CONFIG.wordCount,
      tags:      POST_CONFIG.tags
    });
    AF.renderTerminal('#post-terminal', { lines: POST_CONFIG.terminalLines });
    AF.renderFooter('#post-footer', {
      label:  POST_CONFIG.footerLabel,
      author: POST_CONFIG.footerAuthor,
      year:   POST_CONFIG.footerYear
    });
  }

  function buildFallbackFramework() {
    function $i(sel) { return typeof sel === 'string' ? document.querySelector(sel) : sel; }
    function inj(t, h) { var el = $i(t); if (el) el.innerHTML = h; }
    return {
      renderEngineeringPassport: function(t, o) {
        o = o || {};
        var status  = (o.status || 'DRAFT').toUpperCase();
        var rt = o.readTime || (o.wordCount ? '~'+Math.ceil(Number(o.wordCount)/200)+' MIN' : null);
        var meta = [ {k:'AUTH',v:o.author||'—'}, {k:'CREATED',v:o.created||'—'} ];
        if (o.modified) meta.push({k:'LAST_MODIFIED',v:o.modified});
        if (rt)         meta.push({k:'READ',v:rt});
        var metaHTML = meta.map(function(m){ return '<span class="bp-meta-item"><b>'+m.k+'</b>: '+m.v+'</span>'; }).join('');
        var tags = Array.isArray(o.tags) ? o.tags : [];
        function toSlug(s) { return s.toLowerCase().replace(/\s+/g,'-'); }
        var tagsHTML = tags.length ? '<div class="bp-tags">'+tags.map(function(tg){ return '<a href="https://www.pavelzosim.com/blog/tags/'+toSlug(tg)+'" class="atlas-blueprint-link" target="_top">#'+tg+'</a>'; }).join('')+'</div>' : '';
        inj(t,
          '<div class="passport-bp">'+
            '<div class="bp-title-bar">'+
              '<div class="bp-title-bar__left">'+
                '<span class="bp-user-prompt">'+(o.user||'pavelzosim')+'</span>'+
                '<span style="opacity:.4">:</span>'+
                '<span class="bp-path-prompt">'+(o.path||'~')+'</span>'+
                '<span class="bp-root-char">#</span>'+
                '<span class="bp-command-text">'+(o.command||'cat log')+'</span>'+
              '</div>'+
              '<div class="bp-sys-status">[ SYS_STATUS: <b>'+status+'</b> ]</div>'+
            '</div>'+
            (o.title ? '<div class="bp-main-title">'+o.title+'</div>' : '')+
            '<div class="bp-grid">'+
              '<div class="bp-cell"><div><span class="bp-key">PROJECT</span><span class="bp-val">'+(o.project||'—')+'</span></div><div><span class="bp-key">MODULE</span><span class="bp-val">'+(o.module||'—')+'</span></div></div>'+
              '<div class="bp-cell"><div><span class="bp-key">VERSION</span><span class="bp-val">'+(o.version||'—')+'</span></div><div><span class="bp-key">LOG_ID</span><span class="bp-val">'+(o.logId||'—')+'</span></div></div>'+
            '</div>'+
            '<div class="bp-meta">'+metaHTML+'</div>'+
            tagsHTML+
          '</div>');
      },
      renderTerminal: function(t, o) {
        o = o || {};
        var lines = (o.lines||[]).map(function(l){
          return l.replace(/\*\*(.+?)\*\*/g,'<b>$1</b>').replace(/!!(.+?)!!/g,'<span class="red">$1</span>').replace(/~~(.+?)~~/g,'<span class="ok">$1</span>');
        }).join('\n');
        inj(t,'<div class="atlas-terminal">'+lines+'</div>');
      },
      renderFooter: function(t, o) {
        o = o || {};
        var right = o.author ? o.author+' // '+(o.year||new Date().getFullYear()) : String(o.year||new Date().getFullYear());
        inj(t,'<div class="atlas-post-footer"><span>'+(o.label||'// END OF LOG')+'</span><span>'+right+'</span></div>');
      }
    };
  }

  if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', tryInit); }
  else { tryInit(); }
}());
</script>

</body>
</html>