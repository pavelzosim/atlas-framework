-.2H16v5.371a.2.2 0 0 1-.2.2h-.529a.2.2 0 0 1-.2-.2zm-6.5 6.9v.529a.2.2 0 0 1-.2.2H3v-5.371c0-.11.09-.2.2-.2h.529c.11 0 .2.09.2.2v3.786l4.355-4.356a.2.2 0 0 1 .283 0l.374.374a.2.2 0 0 1 0 .283L4.585 15.07h3.786c.11 0 .2.09.2.2z" fill="#000" fill-rule="nonzero"></path></svg></button></div></figure></div></div></div><div type="image" data-hook="rcv-block384"></div><div data-breakout="normal"><div class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-wwl5968961"><span class="ATqq4"><br role="presentation"/></span></div></div><div type="empty-line" data-hook="rcv-block385"></div><div data-breakout="normal"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-2pwjp70194"><span class="ATqq4"><span style="font-size:16px"><span>Now, what would happen if we activated ZTest Always? In this case, Depth Testing would not</span></span></span></p></div><div type="paragraph" data-hook="rcv-block386"></div><div data-breakout="normal"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-y0d9n71428"><span class="ATqq4"><span style="font-size:16px"><span>be done, therefore, all pixels would appear at the same depth on screen.</span></span></span></p></div><div type="paragraph" data-hook="rcv-block387"></div><div data-breakout="normal"><div class="Ty9C4" id="viewer-844fr110388"><div class="_5TbcM MP9Zu"><figure class="Exewp" data-hook="figure-IMAGE"><div data-hook="image-viewer" class="qW3Ua"><div style="--dim-height:325;--dim-width:942;--ricos-image-default-border-color:unset" id="844fr110388" class="_3Eesd _04b1m rV-M1" data-hook="image-viewer-844fr110388"><wow-image id="ace175_98de10737455418a8dd9979889f81010~mv2.png" class="undefined s9SHU" data-image-info="{&quot;containerId&quot;:&quot;844fr110388&quot;,&quot;alignType&quot;:&quot;center&quot;,&quot;displayMode&quot;:&quot;fill&quot;,&quot;isLQIP&quot;:true,&quot;isSEOBot&quot;:false,&quot;lqipTransition&quot;:&quot;blur&quot;,&quot;encoding&quot;:&quot;AVIF&quot;,&quot;imageData&quot;:{&quot;width&quot;:942,&quot;height&