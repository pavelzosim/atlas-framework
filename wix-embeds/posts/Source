" style="width:100%;height:100%;object-fit:cover;object-position:50% 50%;max-width:100%;position:absolute;left:0;top:0" data-pin-url="https://www.pavelzosim.com/post/unity-shaderlab-cheatsheet" data-pin-media="https://static.wixstatic.com/media/ace175_98de10737455418a8dd9979889f81010~mv2.png/v1/fill/w_1130,h_390,al_c,lg_1,q_90/ace175_98de10737455418a8dd9979889f81010~mv2.png" draggable="false"/></wow-image></div><button class="vOU3n" type="button" data-hook="image-expand-button" aria-label="Expand image"><svg viewBox="0 0 19 19" xmlns="http://www.w3.org/2000/svg" class="ygD6o"><path d="M15.071 8.371V4.585l-4.355 4.356a.2.2 0 0 1-.283 0l-.374-.374a.2.2 0 0 1 0-.283l4.356-4.355h-3.786a.2.2 0 0 1-.2-.2V3.2c0-.11.09-.2.2-.2H16v5.371a.2.2 0 0 1-.2.2h-.529a.2.2 0 0 1-.2-.2zm-6.5 6.9v.529a.2.2 0 0 1-.2.2H3v-5.371c0-.11.09-.2.2-.2h.529c.11 0 .2.09.2.2v3.786l4.355-4.356a.2.2 0 0 1 .283 0l.374.374a.2.2 0 0 1 0 .283L4.585 15.07h3.786c.11 0 .2.09.2.2z" fill="#000" fill-rule="nonzero"></path></svg></button></div></figure></div></div></div><div type="image" data-hook="rcv-block388"></div><div data-breakout="normal"><div class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-ewdpr76327"><span class="ATqq4"><br role="presentation"/></span></div></div><div type="empty-line" data-hook="rcv-block389"></div><div data-breakout="normal"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-x1sou33948"><span class="ATqq4"><em style="font-style:italic"><span style="font-size:16px"><span>Example:</span></span></em></span></p></div><div type="paragraph" data-hook="rcv-block390"></div><div data-breakout="normal"><div class="Ty9C4" id="viewer-qaw3w22892"><div class="_5TbcM" style="width:min(100%, 940px)"><div class="bm-Gu" style="width:940;height:224px;max-height:224px" data-hook="html-component"></div></div></div></div><div type="html" data-hook="rcv-block391"></div><div data-breakout="normal"><div class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-hvdxn22894"><span class="ATqq4"><br role="presentation"/></span></div></div><div type="empty-line" data-hook="rcv-block392"></div><div data-breakout="normal"><div class="Ty9C4" id="viewer-bnqto78793"><div class="_5TbcM RuCAA"><div class="AWQ51" data-hook="divider divider-dotted" role="separator" aria-orientation="horizontal"><div class="bW26w"><svg class="_95FC7 J0-kr oi-6V x4Dgj"><line x2="100%" y1="1" y2="1"></line></svg><div class="vL2Q2"> </div></div></div></div></div></div><div type="divider" data-hook="rcv-block393"></div><div data-breakout="normal"><div class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-73njz60368"><span class="ATqq4"><br role="presentation"/></span></div></div><div type="empty-line" data-hook="rcv-block394"></div><div data-breakout="normal"><h4 class="QlafB _16xou DcaPr o-zp-" dir="auto" tabindex="-1" id="viewer-mksv984982"><span aria-hidden="true" id="454-shaderlab-stencil-mksv9849"></span><span class="-kP5W"><span>4.5.4 ShaderLab Stencil</span></span></h4></div><div type="heading" data-hook="rcv-block395"></div><div data-breakout="normal"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-yrqc161589"><span class="ATqq4"><span style="font-size:16px"><span>The </span></span><strong style="font-weight:700"><span style="font-size:16px"><span>Stencil Buffer</span></span></strong><span style="font-size:16px"><span> is a specialized buffer that stores an 8-bit integer (values 0–255) for each pixel in the Frame Buffer. Before executing the fragment shader for a pixel, the GPU can perform a </span></span><strong style="font-weight:700"><span style="font-size:16px"><span>Stencil Test </span></span></strong><span style="font-size:16px"><span>— comparing the current value in the Stencil Buffer with a specified reference value. If the test passes, the GPU then performs the depth test; if it fails, the GPU skips further processing for that pixel. Essentially, the Stencil Buffer acts as a mask, letting you control which pixels are drawn and which are discarded.</span></span></span></p></div><div type="paragraph" data-hook="rcv-block396"></div><div data-breakout="fullWidth"><div class="Ty9C4" id="viewer-vifyn130929"><div class="_5TbcM"><figure class="Exewp" data-hook="figure-IMAGE"><div data-hook="image-viewer" class="qW3Ua"><div style="--dim-height:455;--dim-width:919;--ricos-image-default-border-color:unset" id="vifyn130929" class="_3Eesd _04b1m rV-M1" data-hook="image-viewer-vifyn130929"><wow-image id="ace175_0cee99e88fe04eb28a8957883aceda01~mv2.png" class="undefined s9SHU" data-image-info="{&quot;containerId&quot;:&quot;vifyn130929&quot;,&quot;alignType&quot;:&quot;center&quot;,&quot;displayMode&quot;:&quot;fill&quot;,&quot;isLQIP&quot;:true,&quot;isSEOBot&quot;:false,&quot;lqipTransition&quot;:&quot;blur&quot;,&quot;encoding&quot;:&quot;AVIF&quot;,&quot;imageData&quot;:{&quot;width&quot;:919,&quot;height&quot;:455,&quot;uri&quot;:&quot;ace175_0cee99e88fe04eb28a8957883aceda01~mv2.png&quot;,&quot;name&quot;:&quot;&quot;,&quot;displayMode&quot;:&quot;fill&quot;}}" data-motion-part="BG_IMG vifyn130929" data-bg-effect-name="" data-has-ssr-src="true" data-animate-blur="" data-is-responsive="true"><img src="https://static.wixstatic.com/media/ace175_0cee99e88fe04eb28a8957883aceda01~mv2.png/v1/fill/w_46,h_23,al_c,q_85,usm_0.66_1.00_0.01,blur_2,enc_avif,quality_auto/ace175_0cee99e88fe04eb28a8957883aceda01~mv2.png" alt="shaderlab stencil " style="width:100%;height:100%;object-fit:cover;object-position:50% 50%;max-width:100%;position:absolute;left:0;top:0" data-pin-url="https://www.pavelzosim.com/post/unity-shaderlab-cheatsheet" data-pin-media="https://static.wixstatic.com/media/ace175_0cee99e88fe04eb28a8957883aceda01~mv2.png/v1/fill/w_919,h_455,al_c,q_90/ace175_0cee99e88fe04eb28a8957883aceda01~mv2.png" draggable="false"/></wow-image></div><button class="vOU3n" type="button" data-hook="image-expand-button" aria-label="Expand image"><svg viewBox="0 0 19 19" xmlns="http://www.w3.org/2000/svg" class="ygD6o"><path d="M15.071 8.371V4.585l-4.355 4.356a.2.2 0 0 1-.283 0l-.374-.374a.2.2 0 0 1 0-.283l4.356-4.355h-3.786a.2.2 0 0 1-.2-.2V3.2c0-.11.09-.2.2-.2H16v5.371a.2.2 0 0 1-.2.2h-.529a.2.2 0 0 1-.2-.2zm-6.5 6.9v.529a.2.2 0 0 1-.2.2H3v-5.371c0-.11.09-.2.2-.2h.529c.11 0 .2.09.2.2v3.786l4.355-4.356a.2.2 0 0 1 .283 0l.374.374a.2.2 0 0 1 0 .283L4.585 15.07h3.786c.11 0 .2.09.2.2z" fill="#000" fill-rule="nonzero"></path></svg></button></div></figure></div></div></div><div type="image" data-hook="rcv-block397"></div><div data-breakout="normal"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-zbxox197209"><span class="ATqq4"><strong style="font-weight:700"><span>How the Stencil Buffer Works</span></strong></span></p></div><div type="paragraph" data-hook="rcv-block398"></div><div data-breakout="normal"><ul class="OYFlQ DcaPr"><li dir="auto" aria-level="1" class="yOSGR" style="text-align:AUTO;font-size:16px;margin-inline-start:1.5em;list-style-type:disc"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="" id="viewer-t1g4j197213"><span class="ATqq4"><strong style="font-weight:700"><span style="font-size:16px"><span>Storage: </span></span></strong><span style="font-size:16px"><span>The Stencil Buffer is like a “texture” that covers the entire frame, with each pixel storing an integer between 0 and 255.</span></span></span></p></li><li dir="auto" aria-level="1" class="yOSGR" style="text-align:AUTO;font-size:16px;margin-inline-start:1.5em;list-style-type:disc"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="" id="viewer-2clvx197217"><span class="ATqq4"><strong style="font-weight:700"><span style="font-size:16px"><span>Stencil Test: </span></span></strong><span style="font-size:16px"><span>Before a fragment is processed, the GPU compares the pixel’s current stencil value (from the buffer) with a reference value that you supply (StencilRef), using a mask (StencilReadMask) and a comparison function (Comp).The test can be conceptually described as:</span></span></span></p></li></ul></div><div type="bulleted_list" data-hook="rcv-block399"></div><div data-hook="gap-spacer" class="xZWzP"></div><div data-breakout="normal"><div class="Ty9C4" id="viewer-54ed8204795"><div class="_5TbcM" style="width:min(100%, 940px)"><div class="bm-Gu" style="width:940;height:126px;max-height:126px" data-hook="html-component"></div></div></div></div><div type="html" data-hook="rcv-block400"></div><div data-breakout="normal"><div class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-2vxw3240077"><span class="ATqq4"><br role="presentation"/></span></div></div><div type="empty-line" data-hook="rcv-block401"></div><div data-breakout="normal"><ul class="OYFlQ DcaPr"><li dir="auto" aria-level="1" class="yOSGR" style="font-size:16px;margin-inline-start:1.5em;list-style-type:disc"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="" id="viewer-eyqy0241605"><span class="ATqq4"><strong style="font-weight:700"><span style="font-size:16px"><span>StencilRef:</span></span></strong><span style="font-size:16px"><span> The reference value you want to compare against. Think of it as an ID you write into the Stencil Buffer.</span></span></span></p></li><li dir="auto" aria-level="1" class="yOSGR" style="font-size:16px;margin-inline-start:1.5em;list-style-type:disc"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="" id="viewer-vjksd220970"><span class="ATqq4"><strong style="font-weight:700"><span style="font-size:16px"><span>StencilReadMask:</span></span></strong><span style="font-size:16px"><span> A mask that determines which bits to consider during the comparison.</span></span></span></p></li><li dir="auto" aria-level="1" class="yOSGR" style="font-size:16px;margin-inline-start:1.5em;list-style-type:disc"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="" id="viewer-637x6220974"><span class="ATqq4"><strong style="font-weight:700"><span style="font-size:16px"><span>Comp:</span></span></strong><span style="font-size:16px"><span> A comparison function that evaluates to true or false (see below).</span></span></span></p></li></ul></div><div type="bulleted_list" data-hook="rcv-block402"></div><div data-breakout="normal"><div class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-cswou234735"><span class="ATqq4"><br role="presentation"/></span></div></div><div type="empty-line" data-hook="rcv-block403"></div><div data-breakout="normal"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-pemxg236262"><span class="ATqq4"><strong style="font-weight:700"><span>Available Comparison Functions</span></strong></span></p></div><div type="paragraph" data-hook="rcv-block404"></div><div data-breakout="normal"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-muxjp220979"><span class="ATqq4"><span style="font-size:16px"><span>The following operators can be used for the stencil comparison:</span></span></span></p></div><div type="paragraph" data-hook="rcv-block405"></div><div data-breakout="normal"><div class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-832tl247719"><span class="ATqq4"><br role="presentation"/></span></div></div><div type="empty-line" data-hook="rcv-block406"></div><div data-breakout="normal"><ul class="OYFlQ DcaPr"><li dir="auto" aria-level="1" class="yOSGR" style="font-size:16px;margin-inline-start:1.5em;list-style-type:disc"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="" id="viewer-bxist220983"><span class="ATqq4"><strong style="font-weight:700"><span style="font-size:16px"><span>Comp Never:</span></span></strong><span style="font-size:16px"><span> Always fails the test.</span></span></span></p></li><li dir="auto" aria-level="1" class="yOSGR" style="font-size:16px;margin-inline-start:1.5em;list-style-type:disc"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="" id="viewer-a8vr9220987"><span class="ATqq4"><strong style="font-weight:700"><span style="font-size:16px"><span>Comp Less:</span></span></strong><span style="font-size:16px"><span> Passes if the reference is less than the buffer value.</span></span></span></p></li><li dir="auto" aria-level="1" class="yOSGR" style="font-size:16px;margin-inline-start:1.5em;list-style-type:disc"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="" id="viewer-mhu7k220991"><span class="ATqq4"><strong style="font-weight:700"><span style="font-size:16px"><span>Comp Equal:</span></span></strong><span style="font-size:16px"><span> Passes if the values are equal.</span></span></span></p></li><li dir="auto" aria-level="1" class="yOSGR" style="font-size:16px;margin-inline-start:1.5em;list-style-type:disc"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="" id="viewer-tvkpe220995"><span class="ATqq4"><strong style="font-weight:700"><span style="font-size:16px"><span>Comp LEqual:</span></span></strong><span style="font-size:16px"><span> Passes if the reference is less than or equal to the buffer value.</span></span></span></p></li><li dir="auto" aria-level="1" class="yOSGR" style="font-size:16px;margin-inline-start:1.5em;list-style-type:disc"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="" id="viewer-5yly8220999"><span class="ATqq4"><strong style="font-weight:700"><span style="font-size:16px"><span>Comp Greater:</span></span></strong><span style="font-size:16px"><span> Passes if the reference is greater than the buffer value.</span></span></span></p></li><li dir="auto" aria-level="1" class="yOSGR" style="font-size:16px;margin-inline-start:1.5em;list-style-type:disc"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="" id="viewer-xwmeh221003"><span class="ATqq4"><strong style="font-weight:700"><span style="font-size:16px"><span>Comp NotEqual:</span></span></strong><span style="font-size:16px"><span> Passes if the values are not equal.</span></span></span></p></li><li dir="auto" aria-level="1" class="yOSGR" style="font-size:16px;margin-inline-start:1.5em;list-style-type:disc"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="" id="viewer-p4ncq221007"><span class="ATqq4"><strong style="font-weight:700"><span style="font-size:16px"><span>Comp GEqual:</span></span></strong><span style="font-size:16px"><span> Passes if the reference is greater than or equal to the buffer value.</span></span></span></p></li><li dir="auto" aria-level="1" class="yOSGR" style="font-size:16px;margin-inline-start:1.5em;list-style-type:disc"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="" id="viewer-ea5m0221011"><span class="ATqq4"><strong style="font-weight:700"><span style="font-size:16px"><span>Comp Always:</span></span></strong><span style="font-size:16px"><span> Always passes the test.</span></span></span></p><div class="-Q4aO hw1z8 DcaPr o-zp-" dir="" id="viewer-jsn1f297233"><span class="ATqq4"><br role="presentation"/></span></div></li></ul></div><div type="bulleted_list" data-hook="rcv-block407"></div><div data-hook="gap-spacer" class="xZWzP"></div><div data-breakout="normal"><div class="Ty9C4" id="viewer-9k7tr290629"><div class="_5TbcM MP9Zu"><figure class="Exewp" data-hook="figure-IMAGE"><div data-hook="image-viewer" class="qW3Ua"><div style="--dim-height:553;--dim-width:1116;--ricos-image-default-border-color:unset" id="9k7tr290629" class="_3Eesd _04b1m rV-M1" data-hook="image-viewer-9k7tr290629"><wow-image id="ace175_2fef40972a01476d80d01b587cc9a3db~mv2.png" class="undefined s9SHU" data-image-info="{&quot;containerId&quot;:&quot;9k7tr290629&quot;,&quot;alignType&quot;:&quot;center&quot;,&quot;displayMode&quot;:&quot;fill&quot;,&quot;isLQIP&quot;:true,&quot;isSEOBot&quot;:false,&quot;lqipTransition&quot;:&quot;blur&quot;,&quot;encoding&quot;:&quot;AVIF&quot;,&quot;imageData&quot;:{&quot;width&quot;:1116,&quot;height&quot;:553,&quot;uri&quot;:&quot;ace175_2fef40972a01476d80d01b587cc9a3db~mv2.png&quot;,&quot;name&quot;:&quot;&quot;,&quot;displayMode&quot;:&quot;fill&quot;}}" data-motion-part="BG_IMG 9k7tr290629" data-bg-effect-name="" data-has-ssr-src="true" data-animate-blur="" data-is-responsive="true"><img src="https://static.wixstatic.com/media/ace175_2fef40972a01476d80d01b587cc9a3db~mv2.png/v1/fill/w_49,h_24,al_c,q_85,usm_0.66_1.00_0.01,blur_2,enc_avif,quality_auto/ace175_2fef40972a01476d80d01b587cc9a3db~mv2.png" alt="stencil ref unity
" style="width:100%;height:100%;object-fit:cover;object-position:50% 50%;max-width:100%;position:absolute;left:0;top:0" data-pin-url="https://www.pavelzosim.com/post/unity-shaderlab-cheatsheet" data-pin-media="https://static.wixstatic.com/media/ace175_2fef40972a01476d80d01b587cc9a3db~mv2.png/v1/fill/w_1116,h_553,al_c,q_90/ace175_2fef40972a01476d80d01b587cc9a3db~mv2.png" draggable="false"/></wow-image></div><button class="vOU3n" type="button" data-hook="image-expand-button" aria-label="Expand image"><svg viewBox="0 0 19 19" xmlns="http://www.w3.org/2000/svg" class="ygD6o"><path d="M15.071 8.371V4.585l-4.355 4.356a.2.2 0 0 1-.283 0l-.374-.374a.2.2 0 0 1 0-.283l4.356-4.355h-3.786a.2.2 0 0 1-.2-.2V3.2c0-.11.09-.2.2-.2H16v5.371a.2.2 0 0 1-.2.2h-.529a.2.2 0 0 1-.2-.2zm-6.5 6.9v.529a.2.2 0 0 1-.2.2H3v-5.371c0-.11.09-.2.2-.2h.529c.11 0 .2.09.2.2v3.786l4.355-4.356a.2.2 0 0 1 .283 0l.374.374a.2.2 0 0 1 0 .283L4.585 15.07h3.786c.11 0 .2.09.2.2z" fill="#000" fill-rule="nonzero"></path></svg></button></div></figure></div></div></div><div type="image" data-hook="rcv-block408"></div><div data-breakout="normal"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-3gon8252316"><span class="ATqq4"><strong style="font-weight:700"><span>Practical Example</span></strong></span></p></div><div type="paragraph" data-hook="rcv-block409"></div><div data-breakout="normal"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-nreuz252318"><span class="ATqq4"><span style="font-size:16px"><span>Suppose you have three objects in your scene—a Cube, a Sphere, and a Square—and you want to use the Square as a mask so that only the Sphere inside the Cube is visible.</span></span></span></p></div><div type="paragraph" data-hook="rcv-block410"></div><div data-breakout="normal"><div class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-e57o9257694"><span class="ATqq4"><br role="presentation"/></span></div></div><div type="empty-line" data-hook="rcv-block411"></div><div data-breakout="normal"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-z5nz6252320"><span class="ATqq4"><span style="font-size:16px"><span>1</span></span><span>.</span><strong style="font-weight:700"><span> Mask Shader (USB_stencil_ref)</span></strong></span></p></div><div type="paragraph" data-hook="rcv-block412"></div><div data-breakout="normal"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-kvpff252322"><span class="ATqq4"><span style="font-size:16px"><span>This shader writes a reference value (for example, 2) into the Stencil Buffer for all pixels covered by the mask (the Square). Since we only need to mark the pixels without drawing any color, we disable color output and depth writing.</span></span></span></p></div><div type="paragraph" data-hook="rcv-block413"></div><div data-breakout="normal"><div class="Ty9C4" id="viewer-7690q258651"><div class="_5TbcM" style="width:min(100%, 940px)"><div class="bm-Gu" style="width:940;height:337px;max-height:337px" data-hook="html-component"></div></div></div></div><div type="html" data-hook="rcv-block414"></div><div data-breakout="normal"><div class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-0cqi2289918"><span class="ATqq4"><br role="presentation"/></span></div></div><div type="empty-line" data-hook="rcv-block415"></div><div data-breakout="normal"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-geynm270082"><span class="ATqq4"><strong style="font-weight:700"><span style="font-size:18px"><span>2. Masked Object Shader (USB_stencil_value)</span></span></strong></span></p></div><div type="paragraph" data-hook="rcv-block416"></div><div data-breakout="normal"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-zc7zl270084"><span class="ATqq4"><span style="font-size:16px"><span>This shader renders the object (e.g., the Cube) but only where the Stencil Test indicates it is not part of the mask. It compares the current Stencil Buffer value with the reference value (2) and uses a comparison function to decide whether to draw a pixel.</span></span></span></p></div><div type="paragraph" data-hook="rcv-block417"></div><div data-breakout="normal"><div class="Ty9C4" id="viewer-j16rb275667"><div class="_5TbcM" style="width:min(100%, 940px)"><div class="bm-Gu" style="width:940;height:581px;max-height:581px" data-hook="html-component"></div></div></div></div><div type="html" data-hook="rcv-block418"></div><div data-breakout="normal"><div class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-240ds275669"><span class="ATqq4"><br role="presentation"/></span></div></div><div type="empty-line" data-hook="rcv-block419"></div><div data-breakout="normal"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="auto" id="viewer-0tzqo267004"><span class="ATqq4"><span style="font-size:16px"><span>In this example:</span></span></span></p></div><div type="paragraph" data-hook="rcv-block420"></div><div data-breakout="normal"><ul class="OYFlQ DcaPr"><li dir="auto" aria-level="1" class="yOSGR" style="font-size:16px;margin-inline-start:1.5em;list-style-type:disc"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="" id="viewer-7fywy284818"><span class="ATqq4"><span style="font-size:16px"><span>The mask shader (USB_stencil_ref) writes a stencil value of 2 over the area of the Square.</span></span></span></p></li><li dir="auto" aria-level="1" class="yOSGR" style="font-size:16px;margin-inline-start:1.5em;list-style-type:disc"><p class="-Q4aO hw1z8 DcaPr o-zp-" dir="" id="viewer-c6zg7284821"><span class="ATqq4"><span style="font-size:16px"><span>The masked object shader (USB_stencil_value) renders only where the stencil value is </span></span><strong style="font-weight:700"><span style="font-size:16px"><span>not</span></span></strong><span style="font-size:16px"><span> equal to 2—hiding the Cube where the mask is applied, allowing the Sphere behind it to be visible.</span></span></span></p><div class="-Q4aO hw1z8 DcaPr o-zp-" dir="" id="viewer-smw4z319470"><span class="ATqq4"><br role="presentation"/></span></div></li></ul></div><div type="bulleted_list" data-hook="rcv-block421"></div><div data-hook="gap-spacer" class="xZWzP"></div><div data-breakout="normal"><div class="Ty9C4" id="viewer-6zzpe316151"><div class="_5TbcM MP9Zu"><figure class="Exewp" data-hook="figure-IMAGE"><div data-hook="image-viewer" class="qW3Ua"><div style="--dim-height:322;--dim-width:942;--ricos-image-default-border-color:unset" id="6zzpe316151" class="_3Eesd _04b1m rV-M1" data-hook="image-viewer-6zzpe316151"><wow-image id="ace175_48d961d9427e4f1483305760063db870~mv2.png" class="undefined s9SHU" data-image-info="{&quot;containerId&quot;:&quot;6zzpe316151&quot;,&quot;alignType&quot;:&quot;center&quot;,&quot;displayMode&quot;:&quot;fill&quot;,&quot;isLQIP&quot;:true,&quot;isSEOBot&quot;:false,&quot;lqipTransition&quot;:&quot;blur&quot;,&quot;encoding&quot;:&quot;AVIF&quot;,&quot;imageData&quot;:{&quot;width&quot;:942,&quot;height&quot;:322,&quot;uri&quot;:&quot;ace175_48d961d9427e4f1483305760063db870~mv2.png&quot;,&quot;name&quot;:&quot;&quot;,&quot;displayMode&quot;:&quot;fill&quot;}}" data-motion-part="BG_IMG 6zzpe316151" data-bg-effect-name="" data-has-ssr-src="true" data-animate-blur="" data-is-responsive="true"><img src="https://static.wixstatic.com/media/ace175_48d961d9427e4f1483305760063db870~mv2.png/v1/fill/w_47,h_16,al_c,q_85,usm_0.66_1.00_0.01,blur_2,enc_avif,quality_auto/ace175_48d961d9427e4f1483305760063db870~mv2.png" alt="unity hlsl mask stencil" style="width:100%;height:100%;object-fit:cover;object-position:50% 50%;max-width:100%;position:absolute;left:0;top:0" data-pin-url="https://www.pavelzosim.com/post/unity-shaderlab-cheatsheet" data-pin-media="https://static.wixstatic.com/media/ace175_48d961d9427e4f1483305760063db870~mv2.png/v1/fill/w_1130,h_386,al_c,lg_1,q_90/ace175_48d961d9427e4f1483305760063db870~mv2.png" draggable="false"/></wow-image></div><button class="vOU3n" type="button" data-hook="image-expand-button" aria-label="Expand image"><svg viewBox="0 0 19 19" xmlns="http://www.w3.org/2000/svg" class="ygD6o"><