nd:', target); return; }\n    el.innerHTML = html;\n  }\n\n  function nowUTC() {\n    var d = new Date();\n    var pad = function(n) { return String(n).padStart(2, '0'); };\n    return d.getUTCFullYear() + '-' + pad(d.getUTCMonth()+1) + '-' + pad(d.getUTCDate()) +\n           ' \/\/ ' + pad(d.getUTCHours()) + ':' + pad(d.getUTCMinutes()) + ' UTC';\n  }\n\n  \/* ── ATLAS_SITE: edit here to update footer site-wide ───────── *\/\n  var ATLAS_SITE = {\n    author:  'Pavel Zosim',\n    year:    '2025',\n    tagline: '( ´◔ ω◔`) ノシ',\n    links: [\n      {\n        label: 'Code & Shared Tools',\n        items: [\n          { text: 'GitHub',  url: 'https:\/\/github.com\/pavelzosim' },\n          { text: 'Gumroad', url: 'https:\/\/gumroad.com\/pavelzosim' }\n        ]\n      },\n      {\n        label: 'Media & Documentation',\n        items: [\n          { text: 'YouTube_Breakdowns', url: 'https:\/\/youtube.com\/@pavelzosim' }\n        ]\n      },\n      {\n        label: 'Direct Communication',\n        items: [\n          { text: 'LinkedIn_Profile', url: 'https:\/\/linkedin.com\/in\/pavelzosim' }\n        ]\n      }\n    ],\n    support: {\n      text: '\/\/ If you find this R&D useful, support future deep-dives:',\n      links: [\n        { text: 'Patreon',          url: 'https:\/\/patreon.com\/pavelzosim' },\n        { text: 'Buy Me a Coffee',  url: 'https:\/\/buymeacoffee.com\/pavelzosim' }\n      ]\n    }\n  };\n  global.ATLAS_SITE = ATLAS_SITE;\n\n  \/* ── helpers exposed for Part 2 ─────────────────────────────── *\/\n  global._atlasInject  = inject;\n  global._atlasNowUTC  = nowUTC;\n\n  \/* ── AtlasFramework: methods 1-3b ───────────────────────────── *\/\n  var AF = {\n\n    \/* 1. WINDOW CHROME *\/\n    renderWindowChrome: function (target, opts) {\n      opts = opts || {};\n      var project   = opts.project     || 'SYSTEM_ATLAS';\n      var module    = opts.module      || '—';\n      var phase     = opts.phase       || 'R&D';\n      var build     = opts.build       || nowUTC();\n      var status    = opts.status      || 'NOMINAL';\n      var statusCls = opts.statusClass || 'status-active';\n      inject(target,\n        '<div class=\"atlas-window-chrome\">' +\n          '<div class=\"atlas-title-bar\">' +\n            '<div class=\"atlas-title-bar__left\">' +\n              '<span class=\"atlas-chrome-btn\">▲<\/span><span>' + project + '<\/span>' +\n            '<\/div>' +\n            '<div class=\"atlas-title-bar__right\">' +\n              '<span class=\"atlas-badge atlas-badge--' +\n                (statusCls==='status-crit'?'crit':statusCls==='status-muted'?'muted':'active') +\n              '\">' + status + '<\/span>' +\n              '<span class=\"atlas-chrome-btn\">—<\/span>' +\n              '<span class=\"atlas-chrome-btn\">□<\/span>' +\n              '<span class=\"atlas-chrome-btn\">✕<\/span>' +\n            '<\/div>' +\n          '<\/div>' +\n          '<div class=\"atlas-info-grid\">' +\n            '<div class=\"atlas-info-cell\">' +\n              '<div><span class=\"atlas-info-cell__key\">PROJECT  <\/span><span class=\"atlas-info-cell__value\">' + project + '<\/span><\/div>' +\n              '<div><span class=\"atlas-info-cell__key\">MODULE   <\/span><span class=\"atlas-info-cell__value\">' + module + '<\/span><\/div>' +\n            '<\/div>' +\n            '<div class=\"atlas-info-cell\">' +\n              '<div><span class=\"atlas-info-cell__key\">PHASE    <\/span><span class=\"atlas-info-cell__value ' + statusCls + '\">' + phase + '<\/span><\/div>' +\n              '<div><span class=\"atlas-info-cell__key\">BUILD    <\/span><span class=\"atlas-info-cell__value\">' + build + '<\/span><\/div>' +\n            '<\/div>' +\n          '<\/div>' +\n        '<\/div>');\n    },\n\n    \/* 2. META HEADER *\/\n    renderMetaHeader: function (target, opts) {\n      opts = opts || {};\n      inject(target,\n        '<div class=\"atlas-meta-header\">' +\n          '<div>' + (opts.left  || '') + '<\/div>' +\n          '<div>' + (opts.right || '') + '<\/div>' +\n        '<\/div>');\n    },\n\n    \/* 3. META FOOTER *\/\n    renderFooter: function (target, opts) {\n      opts = opts || {};\n      var label  = opts.label  || 'End of Report';\n      var author = opts.author || '';\n      var year   = opts.year   || new Date().getFullYear();\n      var right  = author ? author + ' \/\/ ' + year : String(year);\n      inject(target,\n        '<div class=\"atlas-meta-footer\"><div>' + label + '<\/div><div>' + right + '<\/div><\/div>');\n    },\n\n    \/* 3b. SITE FOOTER — reads from ATLAS_SITE *\/\n    renderSiteFooter: function (target, opts) {\n      opts = opts || {};\n      var site    = global.ATLAS_SITE || {};\n      var tagline = opts.tagline || site.tagline || '';\n      var cols    = opts.links   || site.links   || [];\n      var support = opts.support !== undefined ? opts.support : site.support;\n      var html =\n        '<div class=\"atlas-footer\">' +\n          '<div class=\"atlas-footer__title\">' +\n            '<span>0xF00TER \/\/ CONNECT_STAMP<\/span>' +\n            (tagline ? '<span style=\"opacity:.5;\">' + tagline + '<\/span>' : '') +\n          '<\/div>';\n      if (cols.length) {\n        html += '<div class=\"atlas-footer__grid\">';\n        cols.forEach(function(col) {\n          html += '<div class=\"atlas-footer__col\"><span class=\"atlas-footer__col-label\">' + col.label + '<\/span>';\n          (col.items||[]).forEach(function(item) {\n            html += '<a href=\"' + item.url + '\" target=\"_blank\" class=\"atlas-nc-link\">' + item.text + '<\/a>';\n          });\n          html += '<\/div>';\n        });\n        html += '<\/div>';\n      }\n      if (support) {\n        html += '<div class=\"atlas-footer__support\"><span class=\"atlas-footer__support-text\">' + (support.text||'') + '<\/span><div class=\"atlas-footer__support-links\">';\n        (support.links||[]).forEach(function(l) {\n          html += '<a href=\"' + l.url + '\" target=\"_blank\">' + l.text + '<\/a>';\n        });\n        html += '<\/div><\/div>';\n      }\n      html += '<\/div>';\n      inject(target, html);\n    }\n  };\n\n  global.AtlasFramework = AF;\n\n}(window));\n<\/script>\n","category":{"enumClass":"com.wixpress.live.site.data.types.CustomContentCategory","value":"ESSENTIAL"}},"domain":"","name":"atlas-body-end-part1"},{"id":"6f4598b8-c0e1-443c-a252-e8c0bd9bc1bd","embedType":"custom","pages":["dbnc0"],"position":"bodyEnd","loadOnce":false,"content":{"type":"custom","html":"<!--\n  SYSTEM ATLAS FRAMEWORK - BODY-END CUSTOM CODE - PART 2 \/ 2\n  Wix Dashboard -> Settings -> Custom Code -> Body - end\n  Load ORDER: Part 1 first, then Part 2.\n\n  Contains: methods 4-7 + autoMount\n  (renderStatusBar, renderTerminal, renderEngineeringPassport, autoMount)\n-->\n<script>\n(function (global) {\n  'use strict';\n\n  var inject  = global._atlasInject;\n  var nowUTC  = global._atlasNowUTC;\n\n  \/* wait for Part 1 if scripts load out of order *\/\n  function extend() {\n    var AF = global.AtlasFramework;\n    if (!AF) { return setTimeout(extend, 50); }\n\n    \/* 4. STATUS BAR *\/\n    AF.renderStatusBar = function (target, opts) {\n      opts = opts || {};\n      var cells = (opts.items||[]).map(function(item) {\n        return '<span style=\"font-family:var(--atlas-font-mono,monospace);font-size:0.68rem;text-transform:uppercase;letter-spacing:0.08em;margin-right:20px;' +\n          (item.crit ? 'color:var(--atlas-crit,#8b0000);' : 'opacity:0.6;') + '\">' +\n          '<span style=\"opacity:0.5;\">' + item.key + ': <\/span>' +\n          '<strong>' + item.value + '<\/strong><\/span>';\n      }).join('');\n      inject(target,\n        '<div style=\"border:1px solid var(--atlas-border,rgba(0,0,0,.15));padding:6px 12px;background:rgba(0,0,0,.03);display:flex;flex-wrap:wrap;gap:4px;margin-bottom:20px;\">' +\n        cells + '<\/div>');\n    };\n\n    \/* 5. TERMINAL *\/\n    AF.renderTerminal = function (target, opts) {\n      opts = opts || {};\n      var lines = (opts.lines||[]).map(function(l) {\n        return l.replace(\/\\*\\*(.+?)\\*\\*\/g,'<b>$1<\/b>')\n                .replace(\/!!(.+?)!!\/g,'<span class=\"red\">$1<\/span>')\n                .replace(\/~~(.+?)~~\/g,'<span class=\"ok\">$1<\/span>');\n      }).join('\\n');\n      inject(target, '<div class=\"atlas-terminal\">' + lines + '<\/div>');\n    };\n\n    \/* 6. ENGINEERING PASSPORT *\/\n    AF.renderEngineeringPassport = function (target, opts) {\n      opts = opts || {};\n      var project  = opts.project  || '—';\n      var module   = opts.module   || '—';\n      var version  = opts.version  || '—';\n      var logId    = opts.logId    || '—';\n      var status   = (opts.status  || 'DRAFT').toUpperCase();\n      var author   = opts.author   || '—';\n      var created  = opts.created  || '—';\n      var modified = opts.modified || null;\n      var tags     = Array.isArray(opts.tags) ? opts.tags : [];\n      var readTime = opts.readTime || (opts.wordCount ? '~'+Math.ceil(Number(opts.wordCount)\/200)+' MIN' : null);\n\n      var metaItems = [\n        {key:'AUTH',value:author},{key:'CREATED',value:created}\n      ];\n      if (modified) { metaItems.push({key:'LAST_MODIFIED',value:modified}); }\n      if (readTime) { metaItems.push({key:'READ',value:readTime}); }\n\n      var metaHTML = metaItems.map(function(m) {\n        return '<span class=\"bp-meta-item\"><b>'+m.key+'<\/b>: '+m.value+'<\/span>';\n      }).join('');\n\n      function toSlug(s) { return s.toLowerCase().replace(\/\\s+\/g, '-'); }\n      var baseUrl = opts.tagBaseUrl || 'https:\/\/www.pavelzosim.com\/blog\/tags\/';\n      var tagsHTML = tags.length\n        ? '<div class=\"bp-tags\">'+\n            tags.map(function(tg){\n              return '<a href=\"'+baseUrl+toSlug(tg)+'\" class=\"atlas-blueprint-link\" target=\"_top\">#'+tg+'<\/a>';\n            }).join('')+\n          '<\/div>' : '';\n\n      inject(target,\n        '<div class=\"passport-bp\">' +\n          '<div class=\"bp-title-bar\">' +\n            '<div class=\"bp-title-bar__left\">' +\n              '<span class=\"bp-user-prompt\">'+(opts.user||'pavelzosim')+'<\/span>' +\n              '<span style=\"opacity:.4\">:<\/span>' +\n              '<span class=\"bp-path-prompt\">'+(opts.path||'~')+'<\/span>' +\n              '<span class=\"bp-root-char\">#<\/span>' +\n              '<span class=\"bp-command-text\">'+(opts.command||'cat log')+'<\/span>' +\n            '<\/div>' +\n            '<div class=\"bp-sys-status\">[ SYS_STATUS: <b>'+status+'<\/b> ]<\/div>' +\n          '<\/div>' +\n          (opts.title ? '<div class=\"bp-main-title\">'+opts.title+'<\/div>' : '') +\n          '<div class=\"bp-grid\">' +\n            '<div class=\"bp-cell\">' +\n              '<div><span class=\"bp-key\">PROJECT<\/span><span class=\"bp-val\">'+project+'<\/span><\/div>' +\n              '<div><span class=\"bp-key\">MODULE<\/span><span class=\"bp-val\">'+module+'<\/span><\/div>' +\n            '<\/div>' +\n            '<div class=\"bp-cell\">' +\n              '<div><span class=\"bp-key\">VERSION<\/span><span class=\"bp-val\">'+version+'<\/span><\/div>' +\n              '<div><span class=\"bp-key\">LOG_ID<\/span><span class=\"bp-val\">'+logId+'<\/span><\/div>' +\n            '<\/div>' +\n          '<\/div>' +\n          '<div class=\"bp-meta\">'+metaHTML+'<\/div>' +\n          tagsHTML +\n        '<\/div>');\n    };\n\n    \/* 7. AUTO-MOUNT *\/\n    AF.autoMount = function () {\n      document.querySelectorAll('[data-atlas-component]').forEach(function(el) {\n        var type = el.getAttribute('data-atlas-component');\n        var opts = {};\n        Array.prototype.forEach.call(el.attributes, function(attr) {\n          if (attr.name.startsWith('data-atlas-') && attr.name !== 'data-atlas-component') {\n            var key = attr.name.replace('data-atlas-','').replace(\/-([a-z])\/g,function(_,c){return c.toUpperCase();});\n            opts[key] = attr.value;\n          }\n        });\n    