<script>
(function (global) {
  'use strict';

  var inject  = global._atlasInject;
  var nowUTC  = global._atlasNowUTC;

  /* wait for Part 1 if scripts load out of order */
  function extend() {
    var AF = global.AtlasFramework;
    if (!AF) { return setTimeout(extend, 50); }

    /* 4. STATUS BAR */
    AF.renderStatusBar = function (target, opts) {
      opts = opts || {};
      var cells = (opts.items||[]).map(function(item) {
        return '<span style="font-family:var(--atlas-font-mono,monospace);font-size:0.68rem;text-transform:uppercase;letter-spacing:0.08em;margin-right:20px;' +
          (item.crit ? 'color:var(--atlas-crit,#8b0000);' : 'opacity:0.6;') + '">' +
          '<span style="opacity:0.5;">' + item.key + ': </span>' +
          '<strong>' + item.value + '</strong></span>';
      }).join('');
      inject(target,
        '<div style="border:1px solid var(--atlas-border,rgba(0,0,0,.15));padding:6px 12px;background:rgba(0,0,0,.03);display:flex;flex-wrap:wrap;gap:4px;margin-bottom:20px;">' +
        cells + '</div>');
    };

    /* 5. TERMINAL */
    AF.renderTerminal = function (target, opts) {
      opts = opts || {};
      var lines = (opts.lines||[]).map(function(l) {
        return l.replace(/\*\*(.+?)\*\*/g,'<b>$1</b>')
                .replace(/!!(.+?)!!/g,'<span class="red">$1</span>')
                .replace(/~~(.+?)~~/g,'<span class="ok">$1</span>');
      }).join('\n');
      inject(target, '<div class="atlas-terminal">' + lines + '</div>');
    };

    /* 6. ENGINEERING PASSPORT */
    AF.renderEngineeringPassport = function (target, opts) {
      opts = opts || {};
      var project  = opts.project  || '—';
      var module   = opts.module   || '—';
      var version  = opts.version  || '—';
      var logId    = opts.logId    || '—';
      var status   = (opts.status  || 'DRAFT').toUpperCase();
      var author   = opts.author   || '—';
      var created  = opts.created  || '—';
      var modified = opts.modified || null;
      var tags     = Array.isArray(opts.tags) ? opts.tags : [];
      var readTime = opts.readTime || (opts.wordCount ? '~'+Math.ceil(Number(opts.wordCount)/200)+' MIN' : null);

      var metaItems = [
        {key:'AUTH',value:author},{key:'CREATED',value:created}
      ];
      if (modified) { metaItems.push({key:'LAST_MODIFIED',value:modified}); }
      if (readTime) { metaItems.push({key:'READ',value:readTime}); }

      var metaHTML = metaItems.map(function(m) {
        return '<span class="bp-meta-item"><b>'+m.key+'</b>: '+m.value+'</span>';
      }).join('');

      function toSlug(s) { return s.toLowerCase().replace(/\s+/g, '-'); }
      var baseUrl = opts.tagBaseUrl || 'https://www.pavelzosim.com/blog/tags/';
      var tagsHTML = tags.length
        ? '<div class="bp-tags">'+
            tags.map(function(tg){
              return '<a href="'+baseUrl+toSlug(tg)+'" class="atlas-blueprint-link" target="_top">#'+tg+'</a>';
            }).join('')+
          '</div>' : '';

      inject(target,
        '<div class="passport-bp">' +
          '<div class="bp-title-bar">' +
            '<div class="bp-title-bar__left">' +
              '<span class="bp-user-prompt">'+(opts.user||'pavelzosim')+'</span>' +
              '<span style="opacity:.4">:</span>' +
              '<span class="bp-path-prompt">'+(opts.path||'~')+'</span>' +
              '<span class="bp-root-char">#</span>' +
              '<span class="bp-command-text">'+(opts.command||'cat log')+'</span>' +
            '</div>' +
            '<div class="bp-sys-status">[ SYS_STATUS: <b>'+status+'</b> ]</div>' +
          '</div>' +
          (opts.title ? '<div class="bp-main-title">'+opts.title+'</div>' : '') +
          '<div class="bp-grid">' +
            '<div class="bp-cell">' +
              '<div><span class="bp-key">PROJECT</span><span class="bp-val">'+project+'</span></div>' +
              '<div><span class="bp-key">MODULE</span><span class="bp-val">'+module+'</span></div>' +
            '</div>' +
            '<div class="bp-cell">' +
              '<div><span class="bp-key">VERSION</span><span class="bp-val">'+version+'</span></div>' +
              '<div><span class="bp-key">LOG_ID</span><span class="bp-val">'+logId+'</span></div>' +
            '</div>' +
          '</div>' +
          '<div class="bp-meta">'+metaHTML+'</div>' +
          tagsHTML +
        '</div>');
    };

    /* 7. AUTO-MOUNT */
    AF.autoMount = function () {
      document.querySelectorAll('[data-atlas-component]').forEach(function(el) {
