      <style>
  /* 1. ГЛОБАЛЬНЫЙ ФОН */
  body, #site-root, #main_MF {
    background-color: rgb(230, 220, 210) !important;
    background-image: none !important;
  }

  /* 2. КОНТЕЙНЕР ПОСТА (МЯГКИЙ КОНТУР И СЕТКА) */
  article[data-hook="post"] {
    /* Мягкий контур вместо жесткого черного */
    border: 1px solid rgba(0, 0, 0, 0.2) !important;
    margin: 0 auto 40px auto !important;
    padding: 0 !important;
    max-width: 940px !important;
    background-color: rgb(230, 220, 210) !important;
    /* Сетка чуть бледнее */
    background-image: radial-gradient(rgba(0, 0, 0, 0.08) 1px, transparent 1px) !important;
    background-size: 20px 20px !important;
    position: relative;
    z-index: 1;
  }

  /* 3. УДАЛЕНИЕ БЕЛОГО ФОНА (БЕЗ ШРИФТОВ) */
  [data-hook="post-page-root"] div:not([data-hook*="video"]):not([class*="video"]),
  .blog-post-page-root,
  #TPAMultiSection_mmpx3shh,
  [data-testid="post-content-wrapper"] {
    background-color: transparent !important;
    background: transparent !important;
    --postBackgroundColor: transparent !important;
    --ricos-background-color: transparent !important;
    --ricos-background-color-tuple: transparent !important;
    box-shadow: none !important;
    border: none !important;
  }

  /* 4. СХЛОПЫВАНИЕ ОТСТУПОВ МЕНЮ */
  [data-hook="post-page-root"] {
    padding-top: 0 !important;
  }
  [data-hook="categories-nav"] {
    margin-top: 0 !important;
    margin-bottom: 5px !important;
    padding-bottom: 5px !important;
  }
  [data-testid="post-content-wrapper"] {
    margin-top: 0 !important;
    padding-top: 0 !important;
  }

  /* 5. ЗАЩИТА МЕДИА */
  video, img, .qW3Ua, .Ty9C4, [data-hook*="video"], [class*="video"] {
    opacity: 1 !important;
    visibility: visible !important;
    display: block !important;
    background-color: #000 !important;
    width: 100% !important;
    margin: 0 !important;
  }

  /* 6. ПЛОТНОСТЬ КОНТЕНТА */
  .ricos-viewer {
    padding: 0 20px 20px 20px !important;
    background-color: transparent !important;
