<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8">
			<meta name="viewport" content="width=device-width, initial-scale=1.0">

				<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/pavelzosim/atlas-framework@latest/cdn/atlas-framework.css">

					<style>
						html, body {
						margin: 0;
						padding: 20px;
						
						}

						/* ФИКС: убираем заливку фреймворка, чтобы проявить прозрачные линии бордера */
						.content-block .atlas-table {
					
						}
					</style>
				</head>
	<body>

		<div class="content-block">

			<div class="atlas-table-responsive">
				<table class="atlas-table">
					<thead>
						<tr>
							<th>Instance / Pass Name</th>
							<th>Pipeline Module</th>
							<th class="atlas-table-num">Bandwidth / Frame Time</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td>Compute Shader (Sun Surface Volume)</td>
							<td>VFX Runtime</td>
							<td class="atlas-table-num">
								<span class="atlas-param" data-status="ok">1.8 ms</span>
							</td>
						</tr>
						<tr>
							<td>Procedural Explosion Attribute Baking</td>
							<td>Houdini Core</td>
							<td class="atlas-table-num">
								<span class="atlas-param" data-status="warn">84.2%</span>
							</td>
						</tr>
						<tr>
							<td>Vertex Buffer Streaming (Max Load)</td>
							<td>Render Architecture</td>
							<td class="atlas-table-num">
								<span class="atlas-param">180 GB/s</span>
							</td>
						</tr>
						<tr>
							<td>Raymarching Depth Evaluation</td>
							<td>Post-Processing</td>
							<td class="atlas-table-num">
								<span class="atlas-param" data-status="crit">4.1 ms</span>
							</td>
						</tr>
					</tbody>
				</table>
			</div>

		</div>

	</body>
</html>