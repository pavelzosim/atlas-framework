          # 2. Сборка с записью ВЕРСИИ в заголовок
          echo "/* ATLAS FRAMEWORK | VERSION: $VERSION | BUILD: $(date -u) */" > cdn/atlas-framework.css
          
          cat cdn/atlas-core.css >> cdn/atlas-framework.css
          echo -e "\n" >> cdn/atlas-framework.css
          cat cdn/components/*.css >> cdn/atlas-framework.css
          
      - name: Push Result
        run: |
          git config --global user.name "Atlas-CI-Bot"
          git config --global user.email "actions@github.com"
          git add cdn/atlas-framework.css
          
          if ! git diff --staged --quiet; then
            git commit -m "build: release $VERSION [skip ci]"
            git push origin master
          fi

