📜 Локальный скрипт компиляции

Чтобы тебе не нужно было вручную собирать файлы, давай перенесем логику компилятора из раннера в простой локальный Bash-скрипт.

Создай в корне своего проекта файл build.sh (в твоем терминале MINGW64/Git Bash он запустится идеально):
Bash

#!/bin/bash
# ATLAS FRAMEWORK — LOCAL COMPILER

echo "[ATLAS] Starting local compilation..."

# 1. Инициализируем монолит системными шрифтами
printf "@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght=300;400;700&display=swap');\n" > cdn/atlas-framework.css
printf "\n/* ==========================================================================\n   ATLAS FRAMEWORK PRODUCTION CORE — LOCAL MONOLITH\n   ========================================================================== */\n\n" >> cdn/atlas-framework.css

# 2. Функция обработки модулей
process_file() {
  if [ -f "$1" ]; then
    printf "/* ── COMPILER_INJECT: %s ──────────────────────────────── */\n" "$1" >> cdn/atlas-framework.css
    perl -pe 's/\xEF\xBB\xBF//g' "$1" | \
    sed 's|@import url(.*);||g' | \
    sed 's|var(--atlas-font-mono), monospace|var(--atlas-font-mono)|g' >> cdn/atlas-framework.css
    printf "\n\n" >> cdn/atlas-framework.css
    echo " -> Compiled: $1"
  else
    echo " -> WARNING: File not found: $1"
  fi
}

# 3. Конвейер сборки (включай/выключай модули здесь)
process_file "cdn/atlas-core.css"
process_file "cdn/atlas-typography.css"

# Сюда будешь раскомментировать остальные компоненты по мере готовности:
# process_file "cdn/components/atlas-layouts.css"
# process_file "cdn/components/atlas-code-theme.css"

echo "[ATLAS] Monolith compiled successfully into cdn/atlas-framework.css"

