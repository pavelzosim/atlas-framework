          cat cdn/components/atlas-callout.css >> cdn/atlas-framework.css
          cat cdn/components/atlas-code-theme.css >> cdn/atlas-framework.css
          cat cdn/components/atlas-comparison.css >> cdn/atlas-framework.css
          cat cdn/components/atlas-layouts.css >> cdn/atlas-framework.css
          cat cdn/components/atlas-schema.css >> cdn/atlas-framework.css
