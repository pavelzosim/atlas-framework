YAML

name: Atomic Build & Purge

on:
  push:
    tags:
      - 'v*' # Срабатывает только при создании тега

permissions:
  contents: write

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4
        with:
          token: ${{ secrets.GITHUB_TOKEN }}
          fetch-depth: 0

      - name: Atomic Rebuild Monolith
        run: |
          # 1. Полная очистка перед сборкой
          rm -f cdn/atlas-framework.css
          
          # 2. Создание файла с нуля и вшивание тега (Версии)
          echo "/* ==========================================================================" > cdn/atlas-framework.css
          echo "   ATLAS FRAMEWORK PRODUCTION CORE — ATOMIC BUILD" >> cdn/atlas-framework.css
          echo "   VERSION_TAG: ${{ github.ref_name }}" >> cdn/atlas-framework.css
          echo "   BUILD_TIMESTAMP: $(date -u)" >> cdn/atlas-framework.css
          echo "   ========================================================================== */" >> cdn/atlas-framework.css
          echo "" >> cdn/atlas-framework.css
          
          # 3. Чистая сборка модулей
          cat cdn/atlas-core.css >> cdn/atlas-framework.css
          echo -e "\n" >> cdn/atlas-framework.css
          cat cdn/atlas-typography.css >> cdn/atlas-framework.css
          echo -e "\n" >> cdn/atlas-framework.css
          
          # Сборка компонентов из папки (автоматически подхватит все .css файлы)
          for file in cdn/components/*.css; do
            if [ -f "$file" ]; then
              echo "/* Source: $file */" >> cdn/atlas-framework.css
              cat "$file" >> cdn/atlas-framework.css
              echo -e "\n" >> cdn/atlas-framework.css
            fi
          done

      - name: Push Atomic Result
        run: |
          git config --global user.name "Atlas-CI-Bot"
          git config --global user.email "actions@github.com"
          git add cdn/atlas-framework.css
          
          # Коммитим с заменой
          git commit -m "build: atomic rebuild for ${{ github.ref_name }} [skip ci]"
          git push origin HEAD:${{ github.ref }}

      - name: Purge jsDelivr Cache
        run: |
          # Принудительный сброс конкретного тега в CDN
          curl -s "https://purge.jsdelivr.net/gh/pavelzosim/atlas-framework@${{ github.ref_name }}/cdn/atlas-framework.css"

