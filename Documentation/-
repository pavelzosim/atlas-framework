name: Atomic Build & Purge

on:
  push:
    branches:
      - master
    paths-ignore:
      - 'cdn/atlas-framework.css'

permissions:
  contents: write

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          token: ${{ secrets.GITHUB_TOKEN }}
          fetch-depth: 0

      - name: Hard Rebuild
        run: |
          # 1. Получаем текущую версию (тег или коммит)
          VERSION=$(git describe --tags --exact-match 2>/dev/null || echo "dev-${GITHUB_SHA::7}")
          
          # 2. Удаление старого файла
          rm -f cdn/atlas-framework.css
          
          # 3. Создание файла с шапкой
          echo "/* ATLAS FRAMEWORK | VERSION: $VERSION | BUILD: $(date -u) */" > cdn/atlas-framework.css
          
          # 4. Атомарная сборка в строгом порядке:
          # Сначала ядро, затем глобальные стили, затем паспорт, затем остальные компоненты
          cat cdn/atlas-core.css \
              cdn/atlas-typography.css \
              cdn/atlas-layout-global.css \
              cdn/atlas-passport.css \
              cdn/components/*.css >> cdn/atlas-framework.css
          
          # Проверка на пустоту (если сборка упала)
          if [ ! -s cdn/atlas-framework.css ]; then exit 1; fi

      - name: Push Result
        run: |
          git config --global user.name "Atlas-CI-Bot"
          git config --global user.email "actions@github.com"
          git add cdn/atlas-framework.css
          
          # Коммитим, только если были изменения
          if ! git diff --staged --quiet; then
            git commit -m "build: rebuild $(git describe --tags --exact-match 2>/dev/null || echo "dev") [skip ci]"
            git push origin master
          fi

      - name: Purge jsDelivr Cache
        run: |
          # Чистим кэш, чтобы Wix увидел изменения моментально
          curl -s "https://purge.jsdelivr.net/gh/pavelzosim/atlas-framework@master/cdn/atlas-framework.css"

Как теперь организовать файлы (Чек-лист):

    cdn/atlas-core.css — база, переменные, .content-block.

    cdn/atlas-typography.css — стили текста внутри .content-block (без #site-footer!).

    cdn/atlas-layout-global.css — стили для футера (используй класс .atlas-footer-container).

    cdn/atlas-passport.css — тот самый код паспорта, который ты прислал.

    cdn/components/*.css — все остальные модули.

