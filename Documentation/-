name: Atomic Build & Purge


on:

  push:

    branches:

      - master

    paths-ignore:

      - 'cdn/atlas-framework.css'


permissions:

  contents: write


jobs:

  build:

    runs-on: ubuntu-latest

    steps:

      - uses: actions/checkout@v4

        with:

          token: ${{ secrets.GITHUB_TOKEN }}

          fetch-depth: 0


      - name: Hard Rebuild

        run: |

          # 1. Получаем текущую версию (тег или коммит)

          VERSION=$(git describe --tags --exact-match 2>/dev/null || echo "dev-${GITHUB_SHA::7}")

          

          # 2. Удаление и создание файла с нуля

          rm -f cdn/atlas-framework.css

          echo "/* ATLAS FRAMEWORK | VERSION: $VERSION | BUILD: $(date -u) */" > cdn/atlas-framework.css

          

          # 3. Атомарная сборка (сначала корень, потом компоненты)

          find cdn/ -maxdepth 1 -name "*.css" ! -name "atlas-framework.css" -exec cat {} + >> cdn/atlas-framework.css

          echo -e "\n" >> cdn/atlas-framework.css

          find cdn/components/ -name "*.css" -exec cat {} + >> cdn/atlas-framework.css


      - name: Push Result

        run: |

          git config --global user.name "Atlas-CI-Bot"

          git config --global user.email "actions@github.com"

          git add cdn/atlas-framework.css

          if ! git diff --staged --quiet; then

            git commit -m "build: rebuild $(git describe --tags --exact-match 2>/dev/null || echo "dev") [skip ci]"

            git push origin master

          fi


      - name: Purge jsDelivr Cache

        run: |

          # Принудительно чистим кэш после успешного пуша

          curl -s "https://purge.jsdelivr.net/gh/pavelzosim/atlas-framework@master/cdn/atlas-framework.css"

Этот конфиг GitHub Actions теперь полностью корректен и учитывает все твои требования: автоматическую сборку, изоляцию, версионирование и очистку кэша CDN.

Однако, чтобы твоя система стала абсолютно «непробиваемой» (чтобы хедеры Wix не ломались, а компоненты не конфликтовали), тебе нужно сделать финальный шаг в структуре файлов, о котором мы договорились:
Твой финальный чек-лист действий:

    Создай cdn/atlas-passport.css: Перенеси туда весь код паспорта, который ты прислал ранее. Убедись, что все селекторы начинаются с .content-block.

    Создай cdn/atlas-layout-global.css: Перенеси туда стили для футера (те самые, что раньше были в atlas-typography.css с #site-footer).

        Важно: Замени в этом файле #site-footer на .atlas-footer-container, и добавь этот класс в Wix к блоку футера. Это навсегда уберет проблему «плывущего» дизайна.

    Очисти cdn/atlas-typography.css: Удали из него всё, что связано с футером или хедером. Оставь там только чистую типографику, обернутую в .content-block.

Оптимизация сборщика (для максимального контроля)

Чтобы гарантировать порядок сборки (чтобы core всегда был первым, а passport и layout загружались перед остальными компонентами), я рекомендую заменить find ... -exec cat на явный список в твоем YAML-файле.

Вот этот фрагмент сделай таким:
YAML

      - name: Hard Rebuild
        run: |
          VERSION=$(git describe --tags --exact-match 2>/dev/null || echo "dev-${GITHUB_SHA::7}")
          rm -f cdn/atlas-framework.css
          echo "/* ATLAS FRAMEWORK | VERSION: $VERSION | BUILD: $(date -u) */" > cdn/atlas-framework.css
          
          # Явный порядок сборки для предотвращения конфликтов стилей
          cat cdn/atlas-core.css \
              cdn/atlas-typography.css \
              cdn/atlas-layout-global.css \
              cdn/atlas-passport.css \
              cdn/components/*.css >> cdn/atlas-framework.css

Почему эта система теперь — «Золотой стандарт» для РнД:

    Изоляция (Namespace): Благодаря .content-block, твои стили теперь — это «песочница». Они физически не могут выйти за свои пределы и затронуть хедеры или системные элементы Wix.

    Стабильность: Сборка происходит «с чистого листа» (rm -f + cat). Нет риска, что старые стили «залипнут» в монолите.

    Прозрачность: Версия в комментарии (VERSION: vX.Y.Z) позволяет тебе мгновенно понять, какая сборка сейчас активна.

Теперь всё готово. После того как ты разнесешь стили по файлам и закоммитишь этот YAML — твоя система будет работать стабильно, а ошибки в визуализации хедера должны исчезнуть навсегда. Есть ли какой-то конкретный компонент, в котором ты сейчас сомневаешься, или переходим к реализации?

